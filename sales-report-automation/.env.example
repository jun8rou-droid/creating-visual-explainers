# Claude API（必須: 文案生成ステップで使用）
ANTHROPIC_API_KEY=sk-ant-api03-...

# 任意（未設定時は下記デフォルト）
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 週次サマリー文案の「こんな感じで」追指示（改行可。--report-style-file が優先）
# SALES_REPORT_SUMMARY_STYLE=箇条書きは使わず、経営向けに落ち着いた敬体で。冒頭に週キーを1行。

# 週次メール（任意・すべて揃うと pipeline 成功後に SMTP で1通送る）
# SALES_REPORT_SMTP_HOST=smtp.example.com
# SALES_REPORT_SMTP_PORT=587
# SALES_REPORT_SMTP_USE_TLS=1
# SALES_REPORT_SMTP_USER=
# SALES_REPORT_SMTP_PASSWORD=
# SALES_REPORT_MAIL_FROM=report-bot@example.com
# SALES_REPORT_MAIL_TO=you@example.com,boss@example.com
# SALES_REPORT_DASHBOARD_URL=http://127.0.0.1:8080/
