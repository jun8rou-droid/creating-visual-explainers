# ローカル開発用（Vercel ではダッシュボードの環境変数を使う）
# cp .env.example api-server/.env して編集

# PostgreSQL
# ローカル Docker:
# DATABASE_URL=postgresql://machining:machining@localhost:5432/machining_quote
# Neon（Vercel 連携後 · ダッシュボードからコピー）:
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=

# 図面 Vision（未設定時はデモ応答）
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

PORT=3847
