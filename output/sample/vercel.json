{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run migrate",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/",
      "destination": "/machining-quote-4pane-mock.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
